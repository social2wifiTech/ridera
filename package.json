{
  "name": "ridera",
  "version": "0.2.0",
  "description": "Comparador de transporte VTC — Uber, Cabify, Bolt, FREE NOW. Compatible con Node 16.",
  "private": true,
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"nodemon server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "axios": "1.6.7",
    "compression": "1.7.4",
    "cors": "2.8.5",
    "dotenv": "16.4.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "morgan": "1.10.0"
  },
  "devDependencies": {
    "autoprefixer": "10.4.17",
    "concurrently": "8.2.2",
    "nodemon": "3.0.3",
    "postcss": "8.4.33",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1",
    "vite": "4.5.5",
    "@vitejs/plugin-react": "4.2.1",
    "lucide-react": "0.263.1"
  }
}
