# =============================================================================
# Ridera — Variables de Entorno
# =============================================================================
# Copia este archivo como .env.local y rellena los valores.

# Google Maps (opcional — sin él funciona con ubicaciones predefinidas)
GOOGLE_MAPS_API_KEY=

# General
NODE_ENV=development
PORT=3001
DEFAULT_CITY=madrid

# Cache (TTL en segundos)
CACHE_TTL_SECONDS=300

# Rate Limiting (requests por minuto por IP)
RATE_LIMIT_PER_MINUTE=60

# Proveedores — activar/desactivar
PROVIDER_UBER_ENABLED=true
PROVIDER_CABIFY_ENABLED=true
PROVIDER_BOLT_ENABLED=true
PROVIDER_FREENOW_ENABLED=true

# Logging (debug | info | warn | error)
LOG_LEVEL=info
